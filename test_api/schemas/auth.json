{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Auth Response Schema",
  "definitions": {
    "user": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "email_confirmed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_sign_in_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "role": {
          "type": "string"
        },
        "user_metadata": {
          "type": "object"
        },
        "app_metadata": {
          "type": "object"
        }
      },
      "required": ["id", "email", "created_at", "updated_at", "role"]
    },
    "auth_response": {
      "type": "object",
      "properties": {
        "access_token": {
          "type": "string"
        },
        "token_type": {
          "type": "string",
          "enum": ["bearer"]
        },
        "expires_in": {
          "type": "integer",
          "minimum": 1
        },
        "refresh_token": {
          "type": "string"
        },
        "user": {
          "$ref": "#/definitions/user"
        }
      },
      "required": ["access_token", "token_type", "expires_in", "refresh_token", "user"]
    },
    "error_response": {
      "type": "object",
      "properties": {
        "error": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "hint": {
              "type": "string"
            },
            "details": {
              "type": ["object", "null"]
            }
          },
          "required": ["code", "message"]
        }
      },
      "required": ["error"]
    }
  },
  "type": ["object"],
  "anyOf": [
    {
      "$ref": "#/definitions/auth_response"
    },
    {
      "$ref": "#/definitions/error_response"
    }
  ]
}

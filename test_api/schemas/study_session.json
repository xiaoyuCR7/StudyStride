{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Study Session Schema",
  "definitions": {
    "study_session": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "content": {
          "type": "string"
        },
        "duration": {
          "type": "integer",
          "minimum": 0
        },
        "start_time": {
          "type": "string",
          "format": "date-time"
        },
        "end_time": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "session_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "user_id", "subject", "duration", "start_time", "session_date", "created_at", "updated_at"]
    },
    "study_session_create": {
      "type": "object",
      "properties": {
        "user_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "content": {
          "type": "string"
        },
        "duration": {
          "type": "integer",
          "minimum": 0
        },
        "start_time": {
          "type": "string",
          "format": "date-time"
        },
        "end_time": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "session_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      },
      "required": ["user_id", "subject", "duration", "start_time", "session_date"]
    },
    "study_session_list": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/study_session"
      }
    },
    "error_response": {
      "type": "object",
      "properties": {
        "error": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "hint": {
              "type": "string"
            },
            "details": {
              "type": ["object", "null"]
            }
          },
          "required": ["code", "message"]
        }
      },
      "required": ["error"]
    }
  },
  "oneOf": [
    {
      "$ref": "#/definitions/study_session"
    },
    {
      "$ref": "#/definitions/study_session_list"
    },
    {
      "$ref": "#/definitions/error_response"
    }
  ]
}
